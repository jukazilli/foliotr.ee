generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma-client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum PublishState {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AssetKind {
  IMAGE
  DOCUMENT
  VIDEO
  AUDIO
  OTHER
}

enum AssetStatus {
  PENDING
  READY
  FAILED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  username     String?  @unique
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile             Profile?
  accounts            Account[]
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  vocationalTests     VocationalTestSession[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model VocationalTestSession {
  id                   String    @id @default(cuid())
  userId               String
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  methodVersion        String    @default("vocational-v1")
  status               String    @default("draft")
  currentQuestionIndex Int       @default(0)
  profile              Json      @default("{}")
  answers              Json      @default("{}")
  result               Json?
  aiReport             String?   @db.Text
  reportProvider       String?
  reportModel          String?
  reportGeneratedAt    DateTime?
  publicInPortfolio    Boolean   @default(false)
  publicInResume       Boolean   @default(false)
  completedAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([userId, updatedAt])
  @@index([userId, status])
}

model Profile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  displayName    String?
  headline       String?
  bio            String? @db.Text
  avatarUrl      String?
  bannerUrl      String?
  location       String?
  pronouns       String?
  websiteUrl     String?
  publicEmail    String?
  phone          String?
  birthDate      DateTime?
  openToOpportunities     Boolean @default(false)
  opportunityMotivation   String?  @db.Text
  showOpportunityMotivation Boolean @default(false)
  onboardingDone Boolean @default(false)

  experiences  Experience[]
  educations   Education[]
  skills       Skill[]
  projects     Project[]
  achievements Achievement[]
  highlights   Highlight[]
  links        ProfileLink[]
  proofs       Proof[]
  versions     Version[]
  assets       Asset[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Experience {
  id          String              @id @default(cuid())
  profileId   String
  profile     Profile             @relation(fields: [profileId], references: [id], onDelete: Cascade)
  company     String
  role        String
  description String?             @db.Text
  startDate   DateTime
  endDate     DateTime?
  current     Boolean             @default(false)
  location    String?
  logoUrl     String?
  logoAssetId String?
  logoAsset   Asset?              @relation("ExperienceLogoAsset", fields: [logoAssetId], references: [id], onDelete: SetNull)
  order       Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  versions    VersionExperience[]
}

model Education {
  id          String             @id @default(cuid())
  profileId   String
  profile     Profile            @relation(fields: [profileId], references: [id], onDelete: Cascade)
  institution String
  degree      String?
  field       String?
  startDate   DateTime
  endDate     DateTime?
  current     Boolean            @default(false)
  description String?            @db.Text
  logoUrl     String?
  order       Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  versions    VersionEducation[]
}

model Skill {
  id        String         @id @default(cuid())
  profileId String
  profile   Profile        @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name      String
  category  String?
  level     String?
  order     Int            @default(0)
  versions  VersionSkill[]
}

model Project {
  id           String           @id @default(cuid())
  profileId    String
  profile      Profile          @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title        String
  description  String?          @db.Text
  imageUrl     String?
  url          String?
  repoUrl      String?
  tags         String[]
  featured     Boolean          @default(false)
  coverAssetId String?
  coverAsset   Asset?           @relation("ProjectCoverAsset", fields: [coverAssetId], references: [id], onDelete: SetNull)
  coverFitMode String            @default("crop")
  coverPositionX Int             @default(50)
  coverPositionY Int             @default(50)
  order        Int              @default(0)
  startDate    DateTime?
  endDate      DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  versions     VersionProject[]
}

model Achievement {
  id          String               @id @default(cuid())
  profileId   String
  profile     Profile              @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title       String
  description String?              @db.Text
  date        DateTime?
  metric      String?
  imageUrl    String?
  assetId     String?
  asset       Asset?               @relation("AchievementAsset", fields: [assetId], references: [id], onDelete: SetNull)
  order       Int                  @default(0)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  versions    VersionAchievement[]
}

model ProfileLink {
  id        String        @id @default(cuid())
  profileId String
  profile   Profile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  platform  String
  url       String
  label     String?
  order     Int           @default(0)
  versions  VersionLink[]
}

model Proof {
  id          String         @id @default(cuid())
  profileId   String
  profile     Profile        @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title       String
  description String?        @db.Text
  metric      String?
  url         String?
  imageUrl    String?
  assetId     String?
  asset       Asset?         @relation("ProofAsset", fields: [assetId], references: [id], onDelete: SetNull)
  tags        String[]
  reviewerName  String?
  reviewerRole  String?
  reviewerEmail String?
  rating         Int     @default(5)
  isVisible      Boolean @default(false)
  source         String  @default("manual")
  order       Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  versions    VersionProof[]
}

model Highlight {
  id          String             @id @default(cuid())
  profileId   String
  profile     Profile            @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title       String
  description String?            @db.Text
  metric      String?
  assetId     String?
  asset       Asset?             @relation("HighlightAsset", fields: [assetId], references: [id], onDelete: SetNull)
  order       Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  versions    VersionHighlight[]
}

model Asset {
  id                String        @id @default(cuid())
  profileId         String
  profile           Profile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  kind              AssetKind     @default(IMAGE)
  status            AssetStatus   @default(PENDING)
  url               String
  storageKey        String        @unique
  name              String?
  altText           String?
  mimeType          String?
  size              Int?
  width             Int?
  height            Int?
  metadata          Json          @default("{}")
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  projectCovers     Project[]     @relation("ProjectCoverAsset")
  proofAssets       Proof[]       @relation("ProofAsset")
  highlightAssets   Highlight[]   @relation("HighlightAsset")
  experienceLogos   Experience[]  @relation("ExperienceLogoAsset")
  achievementAssets Achievement[] @relation("AchievementAsset")
}

model Version {
  id          String  @id @default(cuid())
  profileId   String
  profile     Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name        String
  description String?
  context     String?
  emoji       String?

  customHeadline String?
  customBio      String? @db.Text

  isDefault Boolean @default(false)

  pages        Page[]
  resumeConfig ResumeConfig?
  experiences  VersionExperience[]
  educations   VersionEducation[]
  projects     VersionProject[]
  skills       VersionSkill[]
  achievements VersionAchievement[]
  proofs       VersionProof[]
  highlights   VersionHighlight[]
  links        VersionLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Template {
  id              String  @id @default(cuid())
  name            String
  slug            String  @unique
  description     String?
  thumbnail       String?
  coverUrl        String?
  referenceUrl    String?
  category        String  @default("general")
  tags            String[]
  libraryStatus   String  @default("available")
  origin          String?
  summary         String?
  detail          String? @db.Text
  sortOrder       Int     @default(0)
  eligibility     Json    @default("{}")
  resumeDefaults  Json    @default("{}")
  restrictions    Json    @default("{}")
  sourcePackage   Json    @default("{}")
  isActive        Boolean @default(true)
  version         Int     @default(1)
  source          String?
  sourceNodeId    String?
  theme           Json    @default("{}")

  blockDefs TemplateBlockDef[]
  pages     Page[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TemplateBlockDef {
  id              String      @id @default(cuid())
  templateId      String
  template        Template    @relation(fields: [templateId], references: [id], onDelete: Cascade)
  key             String
  blockType       String
  label           String
  category        String      @default("section")
  version         Int         @default(1)
  defaultOrder    Int
  required        Boolean     @default(false)
  repeatable      Boolean     @default(false)
  defaultConfig   Json        @default("{}")
  defaultProps    Json        @default("{}")
  editableFields  Json        @default("[]")
  assetFields     Json        @default("[]")
  allowedChildren Json        @default("[]")
  pageBlocks      PageBlock[]

  @@unique([templateId, key])
  @@index([templateId, blockType])
}

model Page {
  id           String       @id @default(cuid())
  versionId    String
  version      Version      @relation(fields: [versionId], references: [id], onDelete: Cascade)
  templateId   String
  template     Template     @relation(fields: [templateId], references: [id])
  slug         String       @unique
  title        String?
  publishState PublishState @default(DRAFT)
  publishedAt  DateTime?
  editorSnapshot    Json    @default("{}")
  publishedSnapshot Json    @default("{}")
  snapshotUpdatedAt DateTime?
  publishedSnapshotAt DateTime?

  blocks PageBlock[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([versionId, templateId])
  @@index([versionId, updatedAt])
}

model PageBlock {
  id                 String            @id @default(cuid())
  pageId             String
  page               Page              @relation(fields: [pageId], references: [id], onDelete: Cascade)
  templateBlockDefId String?
  templateBlockDef   TemplateBlockDef? @relation(fields: [templateBlockDefId], references: [id], onDelete: SetNull)
  parentId           String?
  parent             PageBlock?        @relation("PageBlockTree", fields: [parentId], references: [id], onDelete: Cascade)
  children           PageBlock[]       @relation("PageBlockTree")
  key                String
  blockType          String
  order              Int
  visible            Boolean           @default(true)
  config             Json              @default("{}")
  props              Json              @default("{}")
  assets             Json              @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pageId, parentId, order])
  @@index([templateBlockDefId])
}

model ResumeConfig {
  id        String  @id @default(cuid())
  versionId String  @unique
  version   Version @relation(fields: [versionId], references: [id], onDelete: Cascade)

  sections     String[]
  layout       String       @default("classic")
  accentColor  String?
  showPhoto    Boolean      @default(true)
  showLinks    Boolean      @default(true)
  publishState PublishState @default(DRAFT)
  publishedAt  DateTime?
  publishedSnapshot Json    @default("{}")
  publishedSnapshotAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VersionExperience {
  versionId    String
  experienceId String
  order        Int        @default(0)
  version      Version    @relation(fields: [versionId], references: [id], onDelete: Cascade)
  experience   Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)

  @@id([versionId, experienceId])
  @@index([versionId, order])
}

model VersionEducation {
  versionId   String
  educationId String
  order       Int       @default(0)
  version     Version   @relation(fields: [versionId], references: [id], onDelete: Cascade)
  education   Education @relation(fields: [educationId], references: [id], onDelete: Cascade)

  @@id([versionId, educationId])
  @@index([versionId, order])
}

model VersionProject {
  versionId String
  projectId String
  order     Int     @default(0)
  version   Version @relation(fields: [versionId], references: [id], onDelete: Cascade)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([versionId, projectId])
  @@index([versionId, order])
}

model VersionSkill {
  versionId String
  skillId   String
  order     Int     @default(0)
  version   Version @relation(fields: [versionId], references: [id], onDelete: Cascade)
  skill     Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([versionId, skillId])
  @@index([versionId, order])
}

model VersionAchievement {
  versionId     String
  achievementId String
  order         Int         @default(0)
  version       Version     @relation(fields: [versionId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@id([versionId, achievementId])
  @@index([versionId, order])
}

model VersionProof {
  versionId String
  proofId   String
  order     Int     @default(0)
  version   Version @relation(fields: [versionId], references: [id], onDelete: Cascade)
  proof     Proof   @relation(fields: [proofId], references: [id], onDelete: Cascade)

  @@id([versionId, proofId])
  @@index([versionId, order])
}

model VersionHighlight {
  versionId   String
  highlightId String
  order       Int       @default(0)
  version     Version   @relation(fields: [versionId], references: [id], onDelete: Cascade)
  highlight   Highlight @relation(fields: [highlightId], references: [id], onDelete: Cascade)

  @@id([versionId, highlightId])
  @@index([versionId, order])
}

model VersionLink {
  versionId String
  linkId    String
  order     Int         @default(0)
  version   Version     @relation(fields: [versionId], references: [id], onDelete: Cascade)
  link      ProfileLink @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@id([versionId, linkId])
  @@index([versionId, order])
}
