{
  "name": "foliotree",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "node scripts/serve-port-3000.mjs dev",
    "build": "prisma generate && next build",
    "start": "node scripts/serve-port-3000.mjs start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --max-warnings=0",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run env:check && npm run db:validate && npm run format:check && npm run typecheck && npm run lint && npm run test",
    "env:check": "tsx scripts/check-env.ts",
    "db:validate": "prisma validate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "templates:import": "tsx scripts/import-canonical-templates.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.2.0",
    "@aws-sdk/client-s3": "^3.1032.0",
    "@hookform/resolvers": "^3.6.0",
    "@prisma/client": "^5.14.0",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-slot": "^1.0.2",
    "@smithy/node-http-handler": "^4.5.3",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.395.0",
    "next": "^15.5.15",
    "next-auth": "^5.0.0-beta.31",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.51.5",
    "tailwind-merge": "^2.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "^15.5.15",
    "postcss": "^8",
    "prettier": "^3.8.3",
    "prisma": "^5.14.0",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.15.7",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
